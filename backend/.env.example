# ===========================================
# Backend / Supabase Database
# ===========================================
# Copy to .env and set DATABASE_URL to use Supabase (PostgreSQL).
# Leave DATABASE_URL empty to use local SQLite (fnb.db).

# Supabase PostgreSQL connection string.
# Get it from: https://supabase.com/dashboard → your project → Settings → Database
# → Connection string → URI (use "Transaction" or "Session" pooler for app).
#
# Example (replace YOUR-PASSWORD and project ref):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# Project của bạn: ygmvsmlzpfkznyoayfqy
# Lấy URI tại: https://supabase.com/dashboard/project/ygmvsmlzpfkznyoayfqy/settings/database
#
DATABASE_URL=
